text ArnieDefeated{
    "So strong!"
}

movement Rt1mov1{
    emote_exclamation_mark
}

movement Rt1mov2{
    face_left
}

movement Rt1mov3{
    emote_exclamation_mark
    walk_right
}

movement Rt1mov4{
    emote_exclamation_mark
    walk_right *2
}

movement Rt1mov5{
    emote_exclamation_mark
    walk_right *3
}
