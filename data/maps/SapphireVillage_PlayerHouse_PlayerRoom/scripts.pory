script SapphireVillage_PlaherHouse_PlayerRoom_PC{
    special(DoPCTurnOnEffect)
    playse(SE_PC_ON)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} booted up the PC.")
    special(BedroomPC)
    waitstate
    releaseall
}