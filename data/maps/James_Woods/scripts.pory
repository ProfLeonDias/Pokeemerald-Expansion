script JamesWoods_EventScript_Buneary4A{
    lockall
    delay(30)
    playmoncry(SPECIES_BUNEARY, CRY_MODE_ENCOUNTER)
    waitmoncry
    applymovement(LOCALID_BUNEARY4, JWBunearymov4)
    waitmovement(0)
    delay(15)
    applymovement(OBJ_EVENT_ID_PLAYER, JWPlayermov2x)
    waitmovement(0)
    delay(15)
    addobject(LOCALID_AUSTIN4)
    setobjectxy(LOCALID_AUSTIN4, 33, 54)
    addobject(LOCALID_YOUNGSTER4)
    setobjectxy(LOCALID_YOUNGSTER4, 33, 53)
    addobject(LOCALID_BUGCATCHER4)
    setobjectxy(LOCALID_BUGCATCHER4, 33, 55)
    applymovement(LOCALID_YOUNGSTER4, JWYoungstermov)
    applymovement(LOCALID_AUSTIN4, JWAustinmov3)
    applymovement(LOCALID_BUGCATCHER4, JWAustinmov3)
    waitmovement(0)
    playse(21)
    applymovement(OBJ_EVENT_ID_PLAYER, JWPlayermov3)
    waitmovement(0)
    msgbox("{COLOR BLUE}Austin: There it is!\nAnd this guy too...\pHand over the Buneary or else!\nI need it for my collection!")
    closemessage
    delay(15)
    applymovement(OBJ_EVENT_ID_PLAYER, JWPlayermov4)
    waitmovement(0)
    delay(15)
    applymovement(LOCALID_YOUNGSTER4, JWAustinmov4)
    applymovement(LOCALID_BUGCATCHER4, JWAustinmov4)
    applymovement(LOCALID_AUSTIN4, JWAustinmov4)
    waitmovement(0)
    msgbox("{COLOR BLUE}??? 1: It's three on one.\n??? 2: We can take 'em!")
    closemessage
    delay(15)
    playmoncry(SPECIES_BUNEARY, CRY_MODE_ENCOUNTER)
    waitmoncry
    delay(15)
    playse(54)
    removeobject(LOCALID_BUNEARY4)
    setobjectxy(LOCALID_BUNEARY4, 53, 7)
    addobject(LOCALID_AUSTINBALL)
    setobjectxy(LOCALID_AUSTINBALL, 45, 49)
    delay(30)
    playse(21)
    applymovement(OBJ_EVENT_ID_PLAYER, JWPlayermov5)
    waitmovement(0)
    removeobject(LOCALID_AUSTINBALL)
    setobjectxy(LOCALID_AUSTINBALL, 53, 7)
    msgbox("The Buneary used the spare Poké Ball\nin your back pocket…")
    closemessage
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, JWPlayermov6)
    waitmovement(0)
    msgbox("{COLOR BLUE}Austin: No. Freaking. Way.\pIt let itself be caught by you?\nHand over the Ball, now!\p...\pFine, I'll take it by force!")
    closemessage
    givemon(SPECIES_BUNEARY_STARTER, 5, ITEM_NONE, ITEM_POKE_BALL, NATURE_JOLLY, 0, 0, 0, 0, 0, 0, 0, 0, 31, 31, 31, 31, 31, 31, MOVE_POUND, 0, 0, 0, 1, 0, 0, 0)
    delay(15)
    trainerbattle_no_intro(TRAINER_200, AustinDefeated)
    delay(30)
    msgbox("{COLOR BLUE}??? 1: Woah... Austin lost.\n??? 2: He's never lost before!")
    closemessage
    delay(20)
    applymovement(LOCALID_AUSTIN4, JWAustinmov5)
    waitmovement(0)
    msgbox("{COLOR BLUE}Austin: Why didn't you idiots help me\nout here?!")
    closemessage
    delay(20)
    msgbox("{COLOR BLUE}??? 1: Honestly, I'm getting tired of\nalways being insulted by you.\p??? 2: Yeah, this whole thing has gone\nway too far. Poor Buneary…")   
    closemessage
    delay(15)
    msgbox("{COLOR BLUE}Austin: C'mon, we can still rush 'em and\nmake off with it!")
    closemessage
    delay(15)
    msgbox("{COLOR BLUE}??? 1: Forget this, man.\n??? 2: I'm getting out of here.")
    closemessage
    delay(15)
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_YOUNGSTER4)
    removeobject(LOCALID_BUGCATCHER4)
    fadescreen(FADE_FROM_BLACK)
    delay(15)
    msgbox("{COLOR BLUE}Austin: You two idiots can't just leave\nme here!\p…")
    closemessage
    delay(15)
    applymovement(LOCALID_AUSTIN4, JWAustinmov6)
    waitmovement(0)
    msgbox("{COLOR BLUE}Whatever, keep the Buneary.\nIt's not that strong anyway.\pI'm going to collect all of the rarest\nPokémon in the world!\pNext time I see you, it's payback time.")
    closemessage
    delay(15)
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_AUSTIN4)
    addobject(LOCALID_BUNEARY4)
    setobjectxy(LOCALID_BUNEARY4, 45, 49)
    fadescreen(FADE_FROM_BLACK)
    delay(15)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAustinmov6)
    waitmovement(0)
    delay(15)
    playmoncry(SPECIES_BUNEARY, CRY_MODE_ENCOUNTER)
    waitmoncry
    delay(15)
    msgbox("It seems the Buneary trusts you.\nIt wants to come along with you!")
    closemessage
    fadescreen(FADE_TO_BLACK)
    removeobject(LOCALID_BUNEARY4)
    fadescreen(FADE_FROM_BLACK)
    delay(15)
    msgbox("The Repel's effect wore off…")
    closemessage
    special(HealPlayerParty)
    removeitem(ITEM_SPARE_POKEBALL, 1)
    setvar(VAR_INITIAL_EVENTS, 8)
    setflag(FLAG_HIDE_JAMES_WOODS_PEOPLE4)
    setflag(FLAG_BUNEARY_OBTAINED)
    setflag(FLAG_SYS_POKEMON_GET)
    clearflag(FLAG_NO_ENCOUNTER)
    releaseall
}

script JamesWoods_EventScript_Buneary4B{
    lockall
