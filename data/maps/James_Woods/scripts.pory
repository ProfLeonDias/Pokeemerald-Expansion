mapscripts James_Woods_MapScripts {
    MAP_SCRIPT_ON_TRANSITION: JamesWoodsOnTransition
}

script JamesWoodsOnTransition{
    setflag(FLAG_LANDMARK_FLOWER_SHOP)
    if(var(VAR_ASPEN_LAB_EVENT) == 4){
        removeobject(LOCALID_ALEX)
        removeobject(LOCALID_LYON)
        addobject(LOCALID_TRAINER1)
        addobject(LOCALID_TRAINER2)
        addobject(LOCALID_TRAINER3)
        addobject(LOCALID_TRAINER4)
        addobject(LOCALID_TRAINER5)
        addobject(LOCALID_TRAINER6)
        addobject(LOCALID_BALL1)
        addobject(LOCALID_BALL2)
        setobjectxyperm(LOCALID_TRAINER1, 23, 15)
        setobjectxyperm(LOCALID_TRAINER2, 38, 24)
        setobjectxyperm(LOCALID_TRAINER3, 4, 21)
        setobjectxyperm(LOCALID_TRAINER4, 37, 53)
        setobjectxyperm(LOCALID_TRAINER5, 15, 51)
        setobjectxyperm(LOCALID_TRAINER6, 16, 59)
        setobjectxyperm(LOCALID_BALL1, 45, 26)
        setobjectxyperm(LOCALID_BALL2, 45, 50)
    }
    elif(var(VAR_ASPEN_LAB_EVENT) == 3){
        addobject(LOCALID_ALEX)
        addobject(LOCALID_LYON)
        setobjectxyperm(LOCALID_ALEX, 21, 36)
        setobjectxyperm(LOCALID_LYON, 22, 46)
        addobject(LOCALID_TRAINER1)
        addobject(LOCALID_TRAINER2)
        addobject(LOCALID_TRAINER3)
        addobject(LOCALID_TRAINER4)
        addobject(LOCALID_TRAINER5)
        addobject(LOCALID_TRAINER6)
        addobject(LOCALID_BALL1)
        addobject(LOCALID_BALL2)
        setobjectxyperm(LOCALID_TRAINER1, 23, 15)
        setobjectxyperm(LOCALID_TRAINER2, 38, 24)
        setobjectxyperm(LOCALID_TRAINER3, 4, 21)
        setobjectxyperm(LOCALID_TRAINER4, 37, 53)
        setobjectxyperm(LOCALID_TRAINER5, 15, 51)
        setobjectxyperm(LOCALID_TRAINER6, 16, 59)
        setobjectxyperm(LOCALID_BALL1, 45, 26)
        setobjectxyperm(LOCALID_BALL2, 45, 50)
    }
    elif(var(VAR_ASPEN_EVENTS) == 5){
        addobject(LOCALID_TRAINER1)
        addobject(LOCALID_TRAINER2)
        addobject(LOCALID_TRAINER3)
        addobject(LOCALID_TRAINER4)
        addobject(LOCALID_TRAINER5)
        addobject(LOCALID_TRAINER6)
        addobject(LOCALID_BALL1)
        addobject(LOCALID_BALL2)
        setobjectxyperm(LOCALID_TRAINER1, 23, 15)
        setobjectxyperm(LOCALID_TRAINER2, 38, 24)
        setobjectxyperm(LOCALID_TRAINER3, 4, 21)
        setobjectxyperm(LOCALID_TRAINER4, 37, 53)
        setobjectxyperm(LOCALID_TRAINER5, 15, 51)
        setobjectxyperm(LOCALID_TRAINER6, 16, 59)
        setobjectxyperm(LOCALID_BALL1, 45, 26)
        setobjectxyperm(LOCALID_BALL2, 45, 50)
    }
    else{}
}

script JamesWoods_EventScript_Sign1{
    msgbox("James Woods\pExit north to Sapphire Village.\nExit south to Jasper Town.")
    release
}

script JamesWoods_EventScript_Sign2{
    msgbox("James River\nBeware of the current!")
    release
}

script JamesWoods_EventScript_Sign3{
    msgbox("WARNING!\pThe James River has a dangerously fast\ncurrent. Please do not loiter!\pSponsored by Shining Star Labs")
    release
}

script JamesWoods_EventScript_Sign4{
    msgbox("James Woods\nExit south to Route 1, Jasper Town")
    release
}

script JamesWoods_EventScript_AustinYoungster{
    lock
    faceplayer
    msgbox("{COLOR BLUE}Don't you know when to quit?")
    release
}

script JamesWoods_EventScript_AustinCatcher2{
    lock
    faceplayer
    msgbox("{COLOR BLUE}Get lost already!")
    release
}

script JamesWoods_EventScript_AustinCatcher1{
    lock
    faceplayer
    msgbox("{COLOR BLUE}Don't you have anything else better\nto do?")
    release
}

script JamesWoods_EventScript_YoungsterTile1{
    lockall
    playse(21)
    applymovement(LOCALID_YOUNGSTER2, JWmov1)
    waitmovement(0)
    msgbox("{COLOR BLUE}Hold it, you're not going anywhere!")
    closemessage
    delay(30)
    applymovement(LOCALID_YOUNGSTER2, JWmov2)
    applymovement(OBJ_EVENT_ID_PLAYER, JWmov2)
    waitmovement(0)
    delay(15)
    applymovement(LOCALID_YOUNGSTER2, JWmov3)
    waitmovement(0)
    releaseall
}

