script JamesWoodsHoneyTree {
    lock
    msgbox("There is a sweet scent in the air...")
    closemessage
    checkitem(ITEM_HONEY, 1)
    if (var(VAR_RESULT) == TRUE){
        msgbox("Slather the bark with Honey?", MSGBOX_YESNO)
        if (var(VAR_RESULT) != 0)
        {
            removeitem(ITEM_HONEY, 1)
            msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} slathered the bark with Honey.")
            closemessage
            delay(30)
            playse(21)
            applymovement(OBJ_EVENT_ID_PLAYER, movx2)
            waitmovement(0)
            random(10)
            if (var(VAR_RESULT) == 0){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_COMBEE, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 1){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_COMBEE, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 2){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_COMBEE, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 3){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_HOOTHOOT, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 4){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_HOOTHOOT, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 5){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_DOTTLER, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 6){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_SEEDOT, 10, ITEM_NONE)
                dowildbattle
                release
            }
            if (var(VAR_RESULT) == 7){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_BLIPBUG, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 8){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_BOUNSWEET, 10, ITEM_NONE)
                dowildbattle
                release
            }
            elif (var(VAR_RESULT) == 9){
                msgbox("A wild Pokémon attacked!")
                closemessage
                setwildbattle(SPECIES_BOUNSWEET, 10, ITEM_NONE)
                dowildbattle
                release
            }
        }
        else
        {
            release
        }
    }
    else
    {
        release
    }
}

