script JamesWoods_EventScript_AlexBattle1{
    lockall
    playse(21)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAlexEventmov1)
    waitmovement(0)
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAlexEventmov2)
    waitmovement(0)
    delay(15)
    playbgm(MUS_RG_TITLE, FALSE)
    delay(15)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: There we go, little guy.\nThat Potion should help.")
    closemessage
    removefieldmugshot
    delay(30)
    playse(21)
    applymovement(LOCALID_ALEX, JWAlexEventmov3)
    delay(20)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Hey, {COLOR GREEN}{PLAYER}{COLOR BLUE}!\nCheck it out, I found a Riolu!\pIt looked like the poor little guy was\nabandoned by its Trainer…\pI adopted him and gave him a good meal.\nNow we're best buddies!\p…\pOh, cool! You've got a Pokémon too!\nWe should battle each other!\pHuh?\pWhat's that in your hand?\nA Pokédex from the Professor?")
    closemessage
    removefieldmugshot
    delay(45)
    removeitem(ITEM_SPARE_POKEDEX, 1)
    playfanfare(367)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} delivered the Pokédex.")
    closemessage
    waitfanfare
    delay(45)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: This is so cool!\nWell now I gotta go thank him!")
    closemessage
    removefieldmugshot
    delay(15)
    fadenewbgm(MUS_RG_TITLE)
    delay(60)
    playbgm(MUS_RG_FOLLOW_ME, FALSE)
    applymovement(LOCALID_LYON, JWAlexEventmov4)
    waitmovement(0)
    delay(10)
    createfieldmugshot(MUGSHOT_LYON, 0)
    msgbox("{COLOR BLUE}???: Excuse me. Do you two have a\nminute to talk?")
    closemessage
    removefieldmugshot
    applymovement(LOCALID_ALEX, JWAlexEventmov5)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAlexEventmov5)
    waitmovement(0)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Sure thing, man.\nI'm Alex, and this is {COLOR GREEN}{PLAYER}{COLOR BLUE}.")
    closemessage
    removefieldmugshot
    delay(15)
    createfieldmugshot(MUGSHOT_LYON, 0)
    msgbox("{COLOR BLUE}???: Nice to meet ya. I'm Lyon.\nSorry if I was interrupting anything.")
    closemessage
    removefieldmugshot
    delay(15)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: It's cool, my dude.\nWhat did you wanna talk about?")
    closemessage
    removefieldmugshot
    delay(15)
    createfieldmugshot(MUGSHOT_LYON, 0)
    msgbox("{COLOR BLUE}Lyon: Have you seen a woman around\nhere? Around her late 20s?\lGlasses...Hair color sort of like mine?")
    closemessage
    removefieldmugshot
    delay(15)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Sorry man, haven't seen her.\nIs she your sister or something?")
    closemessage
    removefieldmugshot
    delay(15)
    createfieldmugshot(MUGSHOT_LYON, 0)
    msgbox("{COLOR BLUE}Lyon: Something like that, don't worry\nabout it. Figured she wasn't nearby.\pAnyway, I wouldn't stand here for too\nmuch longer.\pThis bridge is pretty dangerous.\nPeople have fallen off before.")
    closemessage
    removefieldmugshot
    delay(15)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Seems pretty sturdy to us.\nBut, thanks for the tip!")
    closemessage
    removefieldmugshot
    delay(15)
    createfieldmugshot(MUGSHOT_LYON, 0)
    msgbox("{COLOR BLUE}Lyon: Right. Suit yourselves.\nI'll get out of your hair.\pGood luck with your Pokédex quest!")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(LOCALID_LYON, JWAlexEventmov6)
    waitmovement(0)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAlexEventmov7)
    applymovement(LOCALID_ALEX, JWAlexEventmov7)
    waitmovement(0)
    fadenewbgm(MUS_RG_FOLLOW_ME)
    delay(45)
    removeobject(LOCALID_LYON)
    setobjectxyperm(LOCALID_LYON, 52, 3)
    delay(45)
    playbgm(MUS_PETALBURG_WOODS, FALSE)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAlexEventmov8)
    waitmovement(0)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Well, that was weird.\nSeemed like he had a lot on his mind.\pAnyway, before I go back to the village,\nwanna battle?\pC'mon, don't you wanna see who's the\nstronger Trainer?\pI'm warning you, Riolu and I are a team\nthat can't be stopped!")
    closemessage
    removefieldmugshot
    trainerbattle_no_intro(TRAINER_200, AlexDefeated)
    delay(45)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: That. Was. AWESOME!")
    closemessage
    removefieldmugshot
    applymovement(LOCALID_ALEX, JWAlexEventmov9)
    waitmovement(0)
    playse(21)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAlexEventmov10)
    waitmovement(0)
    playse(10)
    applymovement(LOCALID_ALEX, JWAlexEventmov11)
    applymovement(OBJ_EVENT_ID_PLAYER, JWAlexEventmov12)
    waitmovement(0)
    delay(25)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Thanks for the save…\nGuess that Lyon guy had a point.\pI should, uh, go to the Lab so I can\nthank the Professor.\pIt was a ton of fun battling you\n{COLOR GREEN}{PLAYER}{COLOR BLUE}!\pRiolu and I are going to keep training\ntogether! See you around!")
    closemessage
    removefieldmugshot
    delay(25)
    fadeoutbgm(0)
    playbgm(MUS_RG_TITLE, FALSE)
    applymovement(LOCALID_ALEX, JWAlexEventmov13)
    waitmovement(0)
    removeobject(LOCALID_ALEX)
    setobjectxyperm(LOCALID_ALEX, 52, 3)
    setvar(VAR_ASPEN_LAB_EVENT, 4)
    setflag(FLAG_HIDE_ALEX_AND_LYON)
    fadeoutbgm(0)
    playbgm(MUS_PETALBURG_WOODS, FALSE)
    releaseall
}

