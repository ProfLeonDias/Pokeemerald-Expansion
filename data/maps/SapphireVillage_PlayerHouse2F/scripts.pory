}

script SVLHouseScript1{
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR BLUE}: …")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Well, wake up sleepy-head!\pWe're supposed to get our starter\nPokémon today!\pEr… Well…\nI actually went a little earlier.\pI got so excited that I knocked over a\nmachine and broke it.\pThe Professor was so mad that he\nkicked me out.\pSo, could you do me a favor and pick out\nan extra Pokémon for me?")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR BLUE}: …")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Pretty please?\pAlright, fine.\nI'll get a Pokémon somehow.\pYou should hurry though, the Professor\nis already pissed!\pI'll catch up with ya later,{COLOR GREEN}{PLAYER}{COLOR BLUE}!")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(SVAlexHouse, Housemov3)
    waitmovement(0)
    playse(9)
    removeobject(SVAlexHouse)
    setobjectxyperm(SVAlexHouse, 24, 13)
    playbgm(MUS_RG_PALLET, FALSE)
    delay(90)
    setvar(VAR_GAME_INTRO, 4)
    setflag(FLAG_ALEX_CONVO)
    release
}

