mapscripts SapphireVillage_PlayerHouse2F_MapScripts {}

script SapphireVillage_PlayerHouse2F_Alex1{
    lock
    msgbox("{COLOR BLUE}Alex: I'M COMING UP!")
    closemessage
    delay(30)
    playse(21)
    applymovement(OBJ_EVENT_ID_PLAYER, Housemov1)
    waitmovement(0)
    playbgm(MUS_ENCOUNTER_BRENDAN, FALSE)
    playse(9)
    addobject(SVAlexHouse)
    setobjectxy(SVAlexHouse, 18, 2)
    applymovement(SVAlexHouse, Housemov2)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_ALEX, 0)
    msgbox("{COLOR BLUE}Alex: Hey, we were supposed to be at\nProfessor Aspen's Lab today.\pDon't tell me you forgot!\nWait... Hold up.\pYou're looking pretty rough, bruh.\nHaving weird dreams again?")
    closemessage
    removefieldmugshot
    delay(30)
    checkplayergender
    goto_if_eq(VAR_RESULT, MALE, SVLHouseScript1)
    goto_if_eq(VAR_RESULT, FEMALE, SVLHouseScript2)
}

