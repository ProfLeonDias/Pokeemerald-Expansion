movement Housemov1{
    emote_exclamation_mark
    face_up
}

movement Housemov2{
    face_right
    delay_4
    face_down
}

movement Housemov2x{
    face_right
    walk_right
    delay_4
    face_down
}

movement Housemov3{
    face_left
    walk_left
}

movement Housemov3x{
    face_left
    walk_left *2
}