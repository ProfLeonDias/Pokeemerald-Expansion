movement mov1 {
    face_up
}

movement mov2 {
    emote_exclamation_mark
}

movement mov3 {
    walk_down *8
    face_left
}

movement mov3x {
    walk_down *8
    face_right
}

movement mov4 {
    face_right
}

movement mov4x {
    face_left
}

movement mov5 {
    emote_exclamation_mark
    face_up
}

movement mov6 {
    walk_down *7
}

movement mov7 {
    face_up
    walk_up *12
    face_left
    walk_left *6
    face_up
    walk_up
}

movement mov7x {
    face_up
    walk_up *12
    face_left
    walk_left *7
    face_up
    walk_up
}

movement mov8 {
    face_up
    walk_up *13
    face_left
    walk_left *6
    face_up
}

movement mov8x {
    face_up
    walk_up *13
    face_left
    walk_left *7
    face_up
}

movement mov9 {
    face_up
    walk_up
    set_invisible
}

movement mov10{
    face_up
    walk_up *2
    set_invisible
}