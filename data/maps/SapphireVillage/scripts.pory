    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Aspen: I was looking all over for ya!\pWhat the heck were you doing just\nstanding here when I've been waiting\lfor ya all this time?")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR RED}: …")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR BLUE}Anthony: Um, Professor?\nYou know she can't actually-")
    closemessage
    removefieldmugshot
