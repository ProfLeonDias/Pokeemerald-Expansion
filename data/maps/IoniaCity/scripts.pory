script IoniaCity_EventScript_Man1{
    lock
    faceplayer
    msgbox("{COLOR BLUE}A lot of Trainers gather around the\nPower Plant to train.")
    release
}

script IoniaCity_EventScript_Girl1{
    lock
    faceplayer
    msgbox("{COLOR RED}This city is famous for two things:\nThe Power Plant and Zaph.")
    release
}

script IoniaCity_EventScript_Man2{
    lock
    faceplayer
    msgbox("{COLOR BLUE}I saw some weirdos hanging out around\nthe Power Plant.\pI hope they don't come anywhere near\nmy house…")
    release
}

script IoniaCity_EventScript_Girl2{
    lock
    faceplayer
    msgbox("{COLOR RED}I love flowers!")
    release
}

script IoniaCity_EventScript_Man3{
    lock
    faceplayer
    msgbox("{COLOR BLUE}I finally have a girlfriend!\nAren't I cool?")
    release
}

script IoniaCity_EventScript_Girl3{
    lock
    faceplayer
    msgbox("{COLOR RED}We have one hour left.\nAnd touching me will cost extra!")
    release
}

script IoniaCity_EventScript_Man4{
    lock
    faceplayer
    msgbox("{COLOR BLUE}Our Gym Leader Zaph and his older sis,\nMaggie, live here at this house.\pI'm guarding his home while he's away\ndoing super-cool Zaph stuff!\pWell no, he doesn't pay me…\nOr even knows I'm here, but still!\pGet out of here!")
    release
}

script IoniaCity_EventScript_Man5{
    lock
    faceplayer
    msgbox("{COLOR BLUE}I'm sorry, our Aegis Ruins tours are\ncancelled until further notice.\pPlease come again at a later time.")
    release
}

script IoniaCity_EventScript_Katelyn1{
    lockall
    if(var(VAR_POWER_PLANT_STATE) == 5){
        faceplayer
        playbgm(MUS_ENCOUNTER_MAY, FALSE)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: Oh, hello again!\nI'm so glad that you are safe!\pWhat you and Zaph did at the Power\nPlant is all over the news!\pYou must be quite skilled as a Trainer\nto pull that off!\pAs for Zaph, I actually wanted to\nspeak with him, but he ignored me…\pI take it that you would like to face\nhim in a battle, then?\pPerhaps if you battle him, it would\nput him in a better mood…\pBefore anything else, would it be\nalright if we had a quick battle?\pI would like to see how well I can\nmeasure up to someone like you!")
        closemessage
        removefieldmugshot
        delay(30)
        trainerbattle_no_intro(TRAINER_200, IoniaKateDefeated)
        delay(45)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Oh dear, you are really powerful!\pIt seems that the distance I have\ntraveled was not quite enough…\pNever mind that, you are more than\nready to face Zaph!\pEven then, you may need some extra\nassistance, so please take these!")
        closemessage
        removefieldmugshot
        giveitem(ITEM_CHERI_BERRY, 3)
        delay(30)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}I hope that all goes well!\nI will be taking my leave now. Ta-ta!")
        closemessage
        removefieldmugshot
        delay(30)
        fadescreen(FADE_TO_BLACK)
        setflag(FLAG_HIDE_KATELYN_IONIA_CITY)
        removeobject(IoniaKatelyn)
        setobjectxy(IoniaKatelyn, 0, 0)
        fadescreen(FADE_FROM_BLACK)
        setvar(VAR_POWER_PLANT_STATE, 6)
        releaseall
    }
    if(var(VAR_POWER_PLANT_STATE) == 1){
        faceplayer
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: It seems that Zaph has yet\nto return.\pHe must still be occupied by the\nincident at the Power Plant.")
        closemessage
        removefieldmugshot
        releaseall
    }
    if(var(VAR_POWER_PLANT_STATE) == 0){
        playbgm(MUS_ENCOUNTER_MAY, FALSE)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}???: I hope he returns quickly…\nOh, get a grip, Katelyn!\pYou didn't journey across half of the\nRegion to just give up now…")
        closemessage
        delay(30)
        removefieldmugshot
        playse(21)
        applymovement(IoniaKatelyn, ICKatemov1)
        waitmovement(0)
        faceplayer
        delay(30)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Oh! My apologies!\nI did not hear you approach.\pI assume you would like to challenge\nthe Gym, correct?\pUnfortunately, the Gym Leader was\ncalled up to the Power Plant.\pIt appears to be some kind of\nemergency call.\pHe has been gone for a while, and I am\nnot sure when he will return.\pThat being said, Zaph is a very brave\nand skilled trainer.\pI have faith he will return soon!")
        closemessage
        removefieldmugshot
        playbgm(MUS_RUSTBORO, FALSE)
        setvar(VAR_POWER_PLANT_STATE, 1)
        releaseall
    }
}

text IoniaKateDefeated{
    "My goodness!"
}

