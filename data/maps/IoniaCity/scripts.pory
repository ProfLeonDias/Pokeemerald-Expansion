mapscripts IoniaCity_MapScripts {
    MAP_SCRIPT_ON_TRANSITION : OnTransitionIoniaCity
}

script OnTransitionIoniaCity{
    setflag(FLAG_VISITED_PETALBURG_CITY)
    if(var(VAR_IONIA_GYM) == 3){
        lockall
        addobject(MissosIonia)
        addobject(IoniaKatelyn2)
        setobjectxy(MissosIonia, 25, 13)
        setobjectxy(IoniaKatelyn2, 25, 13)
        playbgm(MUS_ENCOUNTER_MAY, FALSE)
        applymovement(IoniaKatelyn2, ICKatemov2)
        waitmovement(0)
        delay(30)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: Hello again!\nDid you manage to defeat Zaph?\pOh, that is quite the lustrous Gym\nBadge, is it not? Beautiful!\pDoes this imply that Zaph is in a mood\nto talk with me? I've traveled so far-")
        closemessage
        removefieldmugshot
        delay(30)
        msgbox("{COLOR BLUE}???: And what do we have here?")
        closemessage
        delay(30)
        playse(21)
        applymovement(OBJ_EVENT_ID_PLAYER, ICPlayermov2)
        applymovement(IoniaKatelyn2, ICPlayermov2)
        waitmovement(0)
        fadeoutbgm(0)
        delay(30)
        playbgm(MUS_RG_ROCKET_HIDEOUT, FALSE)
        applymovement(MissosIonia, ICMissosmov1)
        waitmovement(0)
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}I spy the Trainer who jeopardized our\noperation at the Power Plant.\pAnd just my luck, I also found the heir\nto the Cullinan Fortune!")
        closemessage
        removefieldmugshot
        delay(30)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: Y-You know who I am?")
        closemessage
        removefieldmugshot
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}???: But of course!\nIt IS my mission to dispose of you.\pWe can't allow someone as important\nas you to keep running around like this.")
        closemessage
        removefieldmugshot
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: Let's get out of here\n{COLOR GREEN}{PLAYER}{COLOR RED}!")
        closemessage
        removefieldmugshot
        delay(30)
        playse(15)
        addobject(IoniaDusknoir)
        setobjectxy(IoniaDusknoir, 31, 14)
        playmoncry(SPECIES_DUSKNOIR, CRY_MODE_ENCOUNTER)
        waitmoncry
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}???: Shall we make this quick?\nDuskno-")
        closemessage
        removefieldmugshot
        playse(263)
        delay(45)
        applymovement(MissosIonia, ICMissosmov2)
        waitmovement(0)
        playse(110)
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}???: Yes, what is it now Fia?")
        closemessage
        removefieldmugshot
        delay(30)
        msgbox("{COLOR RED}Fia: Missos, are you done with your\nmission just yet?\pHer Grace is requesting your presence\nback at the home base.")
        closemessage
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}Missos: In a bit, I have a few loose\nends to tie up.\pI will dispose of the heir to the\nCullinan Estate and the Trainer\lwho humiliated you.")
        closemessage
        removefieldmugshot
        delay(30)
        msgbox("{COLOR RED}Fia: Missos, let them be!\nThat is not in your orders!\pMiss Katelyn likely knows nothing, and\n{COLOR GREEN}{PLAYER}{COLOR RED} won fair and square.\pThe mission was still successful\nregardless of their intrusion.\pWhat would Her Grace say if she found\nout you acted out of line!")
        closemessage
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}Missos: Sigh... Very well.\nI'm heading back to base.")
        closemessage
        removefieldmugshot
        delay(30)
        playse(111)
        applymovement(MissosIonia, ICMissosmov3)
        waitmovement(0)
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}As if I care what that woman had to say.\nNow, where were we?")
        closemessage
        removefieldmugshot
        delay(30)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: Missos…\nWhere have I heard that name before?\p...\nWait a minute, you're the-")
        closemessage
        removefieldmugshot
        delay(15)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}Missos: The reason for your\ndisappearance, yes.\pNow, no more bloody interruptions!\nDusknoir, your know what to do.")
        closemessage
        removefieldmugshot
        playmoncry(SPECIES_DUSKNOIR, CRY_MODE_ENCOUNTER)
        waitmoncry
        delay(30)
        applymovement(OBJ_EVENT_ID_PLAYER, ICPlayermov3)
        waitmovement(0)
        delay(30)
        playbgm(0, FALSE)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: {COLOR GREEN}{PLAYER}{COLOR RED}!\nWhat are you doing?\pWe must escape!")
        closemessage
        removefieldmugshot
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}Missos: Oh? You're approaching me?\pInstead of running away, you're coming\nright to me?\pI see, you wish to do battle.\nHehehe… Very well…\pYou do not understand what you have\njust gotten yourself into.\pI am nothing like the pathetic woman\nthat you and Sparky faced.")
        closemessage
        removefieldmugshot
        delay(30)
        setflag(FLAG_DISABLE_RUNNING)
        setflag(FLAG_NO_WHITEOUT)
        setflag(FLAG_FOLLOW_PKMN_DISABLE)
        trainerbattle_no_intro(TRAINER_200, ICMissoslose)
        playbgm(0, FALSE)
        special(HealPlayerParty)
        delay(30)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: Run, {COLOR GREEN}{PLAYER}{COLOR RED}!")
        closemessage
        removefieldmugshot
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}Missos: Dusknoir! End them!")
        closemessage
        removefieldmugshot
        delay(30)
        playmoncry(SPECIES_DUSKNOIR, CRY_MODE_ENCOUNTER)
        waitmoncry
        applymovement(IoniaDusknoir, ICDusknoirmov1)    
        waitmovement(0)
        createfieldmugshot(MUGSHOT_KATELYN, 0)
        msgbox("{COLOR RED}Katelyn: EEEK!")
        closemessage
        removefieldmugshot
        delay(15)
        fadescreen(FADE_TO_BLACK)
        removeobject(IoniaKatelyn2)
        setobjectxyperm(IoniaKatelyn2, 0, 0)
        setobjectxy(OBJ_EVENT_ID_PLAYER, 35, 13)
        fadescreen(FADE_FROM_BLACK)
        delay(15)
        playse(21)
        applymovement(OBJ_EVENT_ID_PLAYER, ICPlayermov4)
        waitmovement(0)
        delay(30)
        createfieldmugshot(MUGSHOT_MISSOS_ROBED, 0)
        msgbox("{COLOR BLUE}Missos: Enjoy your eternal rest.\pThe nightmares will strip away any of\nyour willpower that remains.")
        closemessage
        removefieldmugshot
        playmoncry(SPECIES_DUSKNOIR, CRY_MODE_ENCOUNTER)
        waitmoncry
        applymovement(IoniaDusknoir, ICDusknoirmov2)
        waitmovement(0)
        setvar(VAR_IONIA_GYM, 4)
        setflag(FLAG_HIDE_IONIA_MISSOS)
        clearflag(FLAG_SYS_POKEMON_GET)
        clearflag(FLAG_SYS_POKEDEX_GET)
        clearflag(FLAG_NO_WHITEOUT)
        warp(MAP_IONIA_CITY_NIGHTMARE1, 6, 12)
        releaseall
    }
}

text ICMissoslose{
    "Truly pathetic…"
}

movement ICDusknoirmov1{
    walk_fast_right
}

movement ICDusknoirmov2{
    walk_fast_right *3
    face_up
}

movement ICMissosmov1{
    walk_right *6
}

movement ICMissosmov2{
    emote_question_mark
    face_left
}

movement ICMissosmov3{
    face_right
}

movement ICKatemov2{
    walk_right *8
    face_up
}

movement ICPlayermov2{
    emote_question_mark
    walk_down
    face_left
}

movement ICPlayermov3{
    walk_left
}

movement ICPlayermov4{
    emote_exclamation_mark
    face_left
}

