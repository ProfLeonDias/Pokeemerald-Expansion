movement ICEgyptmov1{
    walk_down *9
}

movement ICEgyptmov2{
    walk_up *9
}

movement ICAnthonymov1{
    walk_down *9
}

movement ICAnthonymov2{
    walk_up *9
}

movement ICPlayermov1{
    face_up
}

movement Ioniamov1{
    emote_exclamation_mark
    face_left
}

movement Ioniamov1x{
    emote_exclamation_mark
    face_left
    walk_left
}

movement Ioniamov1xx{
    emote_exclamation_mark
    face_left
    walk_left *2
}

movement Ioniamov2{
    face_right
}

movement Ioniamov3{
    walk_up
}

movement Ioniamov4{
    face_left
}

movement Ioniamov4x{
    walk_right
    face_left
}

movement Ioniamov4xx{
    walk_right *2
    face_left 
}