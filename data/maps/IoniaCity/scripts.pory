    goto_if_eq(VAR_RESULT, FEMALE, TwinAnthonyD)
}

script NicknamePartyMon{
    msgbox("Do you want to give a nickname\nto this Totodile?", MSGBOX_YESNO)
    if(var(VAR_RESULT) == YES){
        call(Common_EventScript_GetGiftMonPartySlot)
        call(Common_EventScript_NameReceivedPartyMon)
    }
    return
}

script NicknameBoxMon{
    msgbox("Do you want to give a nickname\nto this Totodile?", MSGBOX_YESNO)
        if(var(VAR_RESULT) == YES){
            call(Common_EventScript_NameReceivedBoxMon)
        }
    call(Common_EventScript_TransferredToPC)
    return
}

script TwinEgyptA{
    msgbox("{COLOR RED}???: Hey Bro! Wait up!")
    closemessage
    delay(30)
    playbgm(MUS_ENCOUNTER_MAY, FALSE)
    addobject(EgyptIonia)
    setobjectxy(EgyptIonia, 23, 26)
    applymovement(EgyptIonia, ICEgyptmov1)
    applymovement(OBJ_EVENT_ID_PLAYER, ICPlayermov1)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}Egypt: Finally, I've been looking all\nover for you!\pI finally managed to get Professor\nAspen's PC to work!\pIt wasn't easy, and I'm scarred for life\nby some of the stuff I saw…\pBut hey! We finally got your starter\nPokémon here for you!\pTotodile! Meet {COLOR GREEN}{PLAYER}{COLOR RED}!")
    closemessage
    removefieldmugshot
    delay(50)
    givemon(SPECIES_TOTODILE, 10, ITEM_NONE, ITEM_POKE_BALL, NATURE_NAUGHTY, 0, 0, 0, 0, 0, 0, 0, 0, 21, 21, 21, 21, 21, 21, MOVE_SCRATCH, MOVE_LEER, MOVE_WATER_GUN, MOVE_RAGE, 0, 0, 0, 0)
    if(var(VAR_RESULT) == MON_GIVEN_TO_PARTY){
        playfanfare(MUS_OBTAIN_ITEM)
        msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
        waitfanfare
        waitmessage
        playbgm(MUS_RUSTBORO, FALSE)
        call(NicknamePartyMon)
        goto(TwinEgyptA2)
    }
    elif(var(VAR_RESULT) == MON_GIVEN_TO_PC){
        playfanfare(MUS_OBTAIN_ITEM)
        msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
        waitfanfare
        waitmessage
        playbgm(MUS_RUSTBORO, FALSE)
        call(NicknameBoxMon)
        goto(TwinEgyptA2)
    }
    else{
        msgbox("There's no more room for Pokémon!\pThe Pokémon Boxes are full and can't\naccept any more!")
        waitmessage
        playbgm(MUS_RUSTBORO, FALSE)
        delay(45)
        createfieldmugshot(MUGSHOT_EGYPT, 0)
        msgbox("{COLOR RED}Huh? You don't have any room for it?\nLiterally how though?\pWell, it was the last one after the\nProfessor let me take my pick.\pI picked Treecko, ehehehe…\pSo, what's your next move?\nI can see that shiny new Gym Badge!\pYou're taking on the Nexar League\nwith Alex, aren't you?\pI saw him earlier!\nHe was heading toward the Aegis Ruins.\p
You might be able to catch up with\nhim if you hurry up!\pAs for me, I'm going to stay behind and\nhelp Professor Aspen.\pHe has a lot of issues to work out, so\nI'm gonna help him get better.\pI'll be the first person in his life to\nnever give up on him!\pPlus, with Jonathan's help, I'll get\nfirsthand experience in a lab.\p
My dream of becoming a Pokémon\nProfessor will start to come true!\pWell, I'll see you around, bro!\nGood luck with everything!\pAnd say hi to lil' Bunbun for me!\pOh yeah, come by the Lab later to pick\nup your Totodile!")
        closemessage
        removefieldmugshot
        delay(45)
        playbgm(MUS_ENCOUNTER_MAY, FALSE)
        applymovement(EgyptIonia, ICEgyptmov2)
        waitmovement(0)
        removeobject(EgyptIonia)
        setobjectxyperm(EgyptIonia, 0, 0)
        playbgm(MUS_RUSTBORO, FALSE)
        setflag(FLAG_HIDE_IONIA_TWINS)
        setvar(VAR_IONIA_CITY_STATE, 3)
        releaseall
    }
}

script TwinEgyptA2{
    delay(45)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}Doesn't it look happy to meet you?\nI'm sure you two will get along.\pSadly, it was the last one after the\nProfessor let me take my pick.\pI picked Treecko, ehehehe…\pSo, what's your next move?\nI can see that shiny new Gym Badge!\pYou're taking on the Nexar League\nwith Alex, aren't you?\pI saw him earlier!\nHe was heading toward the Aegis Ruins.\pYou might be able to catch up with him\nif you hurry up!\pAs for me, I'm going to stay behind and\nhelp Professor Aspen.\pHe has a lot of issues to work out, so\nI'm gonna help him get better.\pI'll be the first person in his life to\nnever give up on him!\pPlus, with Jonathan's help, I'll get\nfirsthand experience in a lab.\pMy dream of becoming a Pokémon\nProfessor will start to come true!\pWell, I'll see you around, bro!\nGood luck with everything!\pOh, and say hi to lil' Bunbun for me!")
    closemessage
    removefieldmugshot
    delay(45)
    playbgm(MUS_ENCOUNTER_MAY, FALSE)
    applymovement(EgyptIonia, ICEgyptmov2)
    waitmovement(0)
    removeobject(EgyptIonia)
    setobjectxyperm(EgyptIonia, 0, 0)
    playbgm(MUS_RUSTBORO, FALSE)
    setflag(FLAG_HIDE_IONIA_TWINS)
    setflag(FLAG_OBTAINED_TOTODILE)
    setvar(VAR_IONIA_CITY_STATE, 3)
    releaseall
}

script TwinAnthonyA{
    msgbox("{COLOR BLUE}???: Yo Sis! Wait up!")
    closemessage
    delay(30)
    playbgm(MUS_ENCOUNTER_BRENDAN, FALSE)
    addobject(AnthonyIonia)
    setobjectxy(AnthonyIonia, 23, 26)
    applymovement(AnthonyIonia, ICAnthonymov1)
    waitmovement(0)
    applymovement(OBJ_EVENT_ID_PLAYER, ICPlayermov1)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR BLUE}Anthony: Finally, I've been looking all\nover for ya, sis!\pI finally got Professor Aspen's PC to\nwork, and it wasn't easy!\pHe had way too much weird stuff on\nthere, just like Alex…\pBut hey, we finally got your Starter\nPokémon here for you!\pC'mon Totodile, meet {COLOR GREEN}{PLAYER}{COLOR BLUE}!")
    closemessage
    removefieldmugshot
    delay(50)
    givemon(SPECIES_TOTODILE, 10, ITEM_NONE, ITEM_POKE_BALL, NATURE_NAUGHTY, 0, 0, 0, 0, 0, 0, 0, 0, 21, 21, 21, 21, 21, 21, MOVE_SCRATCH, MOVE_LEER, MOVE_WATER_GUN, MOVE_RAGE, 0, 0, 0, 0)
    if(var(VAR_RESULT) == MON_GIVEN_TO_PARTY){
        playfanfare(MUS_OBTAIN_ITEM)
        msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
        waitfanfare
        waitmessage
        playbgm(MUS_RUSTBORO, FALSE)
        call(NicknamePartyMon)
        goto(TwinAnthonyA2)
    }
    elif(var(VAR_RESULT) == MON_GIVEN_TO_PC){
        playfanfare(MUS_OBTAIN_ITEM)
        msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
