movement DreamCam1{
    walk_up *3
}

movement DreamCam2{
    walk_down *3
}

movement DreamCam3{
    walk_up *3
}

movement DreamCam4{
    walk_down *3
}

movement movdream1{
    emote_question_mark
    face_right
}

movement movdream2{
    face_left
}

movement movdream3{
    face_up
}

movement movdream4{
    face_left
}

movement movdream5{
    face_right
}

movement movdream6{
    face_down
}

movement movdream7{
    face_up
}

movement movdream8{
    emote_exclamation_mark
}

movement movdream9{
    emote_x
    jump_in_place_down
    face_up
}
