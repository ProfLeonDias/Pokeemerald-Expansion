script LabEventBAM{
    msgbox("{COLOR RED}Egypt: Knock-knock!")
    closemessage
    playbgm(MUS_ENCOUNTER_MAY, FALSE)
    addobject(SVLabEgypt)
    setobjectxy(SVLabEgypt, 5, 12)
    applymovement(SVLabEgypt, movEgyptlab3)
    waitmovement(0)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}I'm just popping in!\nMy brother's been taking awhile and-\pOH MY GOSH THAT BUNEARY IS SO FRIGGIN\nCUTE!!!!\pOooh, and it's a Shiny, too!\nThat's the Pokémon you chose?")
    closemessage
    removefieldmugshot
    applymovement(SVLabEgypt, movlabfaceup)
    applymovement(OBJ_EVENT_ID_PLAYER, movlabfaceup)
    waitmovement(0)
    fadeoutbgm(0)
    delay(30)
    playbgm(MUS_RG_OAK_LAB, FALSE)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: I haven't given away any\nPokémon just yet.\pMy PC is not letting me withdraw them\nbecause of some viruses.\pDon't ask how they got there!\nThat's none of your business.")
    closemessage
    removefieldmugshot
    delay(20)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}Egypt: Oh? I can help with that!\nAlex had the same problem before.")
    closemessage
    removefieldmugshot
    delay(20)
    applymovement(SVLabEgypt, movEgyptlab4)
    waitmovement(0)
    delay(20)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}Wait a minute… Professor?\nAre these Pokédexes?")
    closemessage
    removefieldmugshot
    applymovement(SVLabEgypt, movEgyptlab5)
    waitmovement(0)
    delay(20)
    applymovement(SVLabAspen, movAspenlab2)
    waitmovement(0)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: You'd be right.\pI actually wanted to ask ya for another\nfavor…\pLong story short, the Professor's\nCouncil wants to remove my tenure.\pSomething about me not contributing\nenough research or something.\pSince I was gonna give you all a\nPokémon, I figured you'd do it.\pIf ya document the Pokémon that live in\nNexar, that'd be helpful.\pTo tell ya the truth, I ain't good for\nmuch else… Gulp…\pThe pay sucks, but this science lab\nthing is all I got.\pI'll owe ya big time and pay ya back if\nyou help me out!")
    closemessage
    removefieldmugshot
    delay(20)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}Egypt: Ooo, this is so exciting!\nJourneying across Nexar? So jealous!\p{COLOR GREEN}{PLAYER}{COLOR RED}, you and Buneary should\ntotally go for it!\pAlex too, I saw him leaving the Village\nnot too long ago!\pIf you go now, you can probably catch\nup with him!\pDon't worry about us, I'll catch up with\nyou later.")
    closemessage
    removefieldmugshot
    delay(20)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: Glug… Glug…\nThat settles it then!\pHere, take these Pokédexes and give\none of 'em to your brother.\pI'll have your Pokémon delivered to ya\nwhen we're done here.")
    closemessage
    removefieldmugshot
    delay(20)
    applymovement(SVLabEgypt, movEgyptlab6)
    waitmovement(0)
    delay(50)
    applymovement(SVLabAspen, movAspenlab3)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab4)
    waitmovement(0)
    delay(50)
    removeobject(Dex1)
    delay(40)
    removeobject(Dex2)
    delay(40)
    applymovement(SVLabAspen, movAspenlab4)
    waitmovement(0)
    playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} obtained two Pokédexes!")
    closemessage
    waitfanfare
    additem(ITEM_SPARE_POKEDEX, 1)
    delay(80)
    applymovement(SVLabJonathan, movlabjonathan1)
    waitmovement(0)
    delay(20)
    setobjectmovementtype(SVLabJonathan, MOVEMENT_TYPE_LOOK_AROUND)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab5)
    waitmovement(0)
    msgbox("{COLOR BLUE}Jonathan: Oh! Before you go, take\nPoké Balls to start you off.")
    closemessage
    delay(20)
    giveitem(ITEM_POKE_BALL, 10)
    delay(20)
    msgbox("{COLOR BLUE}Good luck out there, and sorry for all\nof the trouble we caused.")
    closemessage
    applymovement(SVLabJonathan, movlabjonathan2)
    waitmovement(0)
    delay(15)
    applymovement(SVLabEgypt, movEgyptlab7)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab6)
    waitmovement(0)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}Egypt: See you later {COLOR GREEN}{PLAYER}{COLOR RED}!")
    closemessage
    removefieldmugshot
    applymovement(SVLabEgypt, movlabfaceup)
    waitmovement(0)
    special(HealPlayerParty)
    setflag(FLAG_SYS_POKEDEX_GET)
    setflag(FLAG_RECEIVED_POKEDEX_FROM_BIRCH)
    setflag(FLAG_HIDE_LAB_DEX)
    setvar(VAR_CABLE_CLUB_TUTORIAL_STATE, 1)
    setvar(VAR_ASPEN_EVENTS, 6)
    setvar(VAR_DELIVERY_EVENTS, 2)
    setvar(VAR_JASPER_TOWN_STATE, 1)
    setvar(VAR_ASPEN_LAB_EVENT, 2)
    releaseall
}

