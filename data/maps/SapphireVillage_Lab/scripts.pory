movement movEgyptlab1{
    walk_right *3
    walk_down *5
}

movement movEgyptlab1x{
    walk_right *3
    walk_down *6
    face_right
}

movement movEgyptlab1xx{
    walk_right *3
    walk_down *3
    walk_right
    walk_down *3
    face_right
}

movement movEgyptlab2{
    walk_right
    walk_down *5
}

movement movEgyptlab2x{
    walk_down *2
    walk_right
    walk_down *2
}

movement movEgyptlab2xx{
    walk_down *4
}

movement movPlayerlab1{
    face_up
}

movement movPlayerlab1x{
    face_left
}

movement movPlayerlab2{
    face_down
}