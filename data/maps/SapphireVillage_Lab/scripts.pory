    closemessage
    removefieldmugshot
    delay(20)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: Glug… Glug…\nThat settles it then!\pHere, take these Pokédexes and give\none of 'em to your brother.\pI'll have your Pokémon delivered to ya\nwhen we're done here.")
    closemessage
    removefieldmugshot
