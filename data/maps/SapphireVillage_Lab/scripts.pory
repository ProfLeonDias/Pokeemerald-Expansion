mapscripts SapphireVillage_Lab_MapScripts {
    MAP_SCRIPT_ON_LOAD: OnLoadSVLab
    MAP_SCRIPT_ON_FRAME_TABLE: OnFrameSVLab
    MAP_SCRIPT_ON_TRANSITION: OnTransitionSVLab
    MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE: OnWarpTableSVLab
}

script OnFrameSVLab{
    lockall
    applymovement(SVLabAspen, movAspenlab5)
    waitmovement(0)
    removeobject(SVLabAspen)
    setobjectxyperm(SVLabAspen, 6, 3)
    setobjectmovementtype(SVLabAspen, MOVEMENT_TYPE_FACE_DOWN)
    clearflag(FLAG_HIDE_LAB_ASPEN)
    applymovement(OBJ_EVENT_ID_PLAYER, movlabmoveup)
    waitmovement(0)
    clearflag(FLAG_DONT_TRANSITION_MUSIC)
	savebgm (MUS_DUMMY)
	fadedefaultbgm
    checkplayergender
    goto_if_eq(VAR_RESULT, MALE, SVLMapScriptX)
    goto_if_eq(VAR_RESULT, FEMALE, SVLMapScriptY)
    return
}

script SVLMapScriptX{
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: Alright, here we go.\pTry not to break anything like your\nbrother did, alright?\pAnyway, your Mom made me have some\nPokémon bred for you guys.\pThere's three Poké Balls on the table,\nso go ahead and take your pick.")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR BLUE}: …")
    closemessage
    removefieldmugshot
    delay(60)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: What are ya waiting for?\nJust pick one already…")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab7)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: That one should contain\nthe Grass-Type Treecko.\pThing's got an attitude…")
    closemessage
    removefieldmugshot
    delay(30)
    playse(22)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab8)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR BLUE}: …")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: Eh? It's empty?\nSorry kid, check the others.")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab9)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: That one should contain\nthe Fire-Type Scorbunny.\pToo much energy for my liking.")
    closemessage
    removefieldmugshot
    delay(30)
    playse(22)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab8)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR BLUE}: …")
    closemessage
    removefieldmugshot
    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: You're kidding me.\nI gave that one away too?\pTry the last one.")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab9)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: That one should have the\nWater-Type Totodile.\pThe bugger nearly bit my hand off…")
    closemessage
    removefieldmugshot
    delay(30)
    playse(22)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab8)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR BLUE}: …")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab10)
    waitmovement(0)
    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: Sorry kid, I guess I\nalready gave all of 'em away.\pBut tell ya what, how about we make a\ndeal instead?\pDown south in Jasper Town I'm\nexpecting a shipment I ordered.\pIf ya go pick it up for me, and I'll have\nnew Pokémon for ya when you get back.\pWhat do ya say? We have a deal?")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(SVLabJonathan, movlabjonathan3)
    waitmovement(0)
    delay(20)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab11)
    waitmovement(0)
    delay(20)
    msgbox("{COLOR BLUE}Jonathan: Pardon my interruption.\pLeaving the village without a single\nPokémon would be dangerous.\pSince our hands are tied, I'll spray you\nwith this long-lasting Repel.")
    closemessage
    playse(1)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} was sprayed with Repel!")
    closemessage
    delay(30)
    msgbox("{COLOR BLUE}Jonathan: While we are at it, you might\nfind these to be useful.")
    closemessage
    delay(30)
    playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} obtained the Running Shoes!")
    waitmessage
    waitfanfare
    msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} switched shoes with the\nRunning Shoes.")
    closemessage
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab12)
    waitmovement(0)
    delay(20)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: Once you get to Jasper\nTown, head towards the Pokémart.\pOnce you're there, ask for a guy named\nMack and tell 'em I sent ya.\pAnd don't let the cops catch ya.\nIf they do, then I don't know ya.")
    closemessage
    removefieldmugshot
    delay(20)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR BLUE}: …")
    closemessage
    removefieldmugshot
    delay(30)
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab11)
    waitmovement(0)
    delay(20)
    msgbox("{COLOR BLUE}Jonathan: What he meant to say was\ngood luck, {COLOR GREEN}{PLAYER}{COLOR BLUE}.\pShow the shopkeeper this Order Form as\nproof that we sent you.")
    closemessage
    delay(20)
    giveitem(ITEM_LETTER, 1)
    delay(30)
    applymovement(SVLabJonathan, movlabjonathan4)
    waitmovement(0)
    delay(30)
    setflag(FLAG_RECEIVED_RUNNING_SHOES)
    setflag(FLAG_SYS_B_DASH)
    setvar(VAR_ASPEN_LAB_EVENT, 1)
    setvar(VAR_ASPEN_EVENTS, 4)
    setvar(VAR_CABLE_CLUB_TUTORIAL_STATE, 1)
    releaseall
}

