movement movlabfaceup{
    face_up
}

movement movlabjonathan1{
    walk_down
    walk_right *4
    walk_up *5
}

movement movlabjonathan2{
    walk_down *5
    walk_left *4
    face_up
}

movement movPlayerlab3{
    face_right
    walk_right
    walk_up *4
}

movement movPlayerlab3x{
    walk_up *4
}

movement movPlayerlab3xx{
    face_left
    walk_left
    walk_up *4
}

movement movPlayerlab4{
    face_up
}

movement movPlayerlab5{
    face_down
}

movement movPlayerlab6{
    face_left
}

movement movAspenlab1{
    emote_exclamation_mark
    face_down
}

movement movAspenlab2{
    face_left
}

movement movAspenlab3{
    walk_left
    walk_up
}

movement movAspenlab4{
    walk_right
    walk_down
}

movement movEgyptlab3{
    walk_up *8
    face_right
}

movement movEgyptlab4{
    walk_up *2
    walk_left
    emote_question_mark
    face_up
}

movement movEgyptlab5{
    face_right
}

movement movEgyptlab6{
    walk_left *2
    face_up
}

movement movEgyptlab7{
    face_right
}

