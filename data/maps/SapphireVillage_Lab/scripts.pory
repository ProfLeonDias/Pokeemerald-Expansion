movement movlabjonathan3{
    face_down
    walk_down
    face_right
    walk_right *4
    walk_up *5
}

movement movlabjonathan4{
    face_down
    walk_down *5
    face_left
    walk_left *4
    face_up
    walk_up
}

movement movAspenlab5{
    walk_up *8
}

movement movlabmoveup{
    walk_up *8
}

movement movPlayerlab7{
    face_down
    walk_down
    face_right
    walk_right *3
    face_up
}

movement movPlayerlab8{
    emote_x
}

movement movPlayerlab9{
    face_right
    walk_right
    face_up
}

movement movPlayerlab10{
    face_left
    walk_left *5
    face_up
    walk_up
}

movement movPlayerlab11{
    face_down
}

movement movPlayerlab12{
    face_up
}

script OnWarpTableSVLab{
    if(var(VAR_ASPEN_EVENTS) == 1){
        turnobject(OBJ_EVENT_ID_PLAYER, MOVEMENT_TYPE_FACE_UP)
    }
}

script OnTransitionSVLab{
    setflag(FLAG_VISITED_LAB)
    if(flag(FLAG_PROF_ASPEN_IMPROVEMENT)){
        call(SVLMapScriptP1)
    }
    elif(var(VAR_ASPEN_LAB_EVENT) >= 3){
        call(SVLMapScriptP2)
    }
    elif(var(VAR_JASPER_TOWN_STATE) == 1){
        call(SVLMapScriptP2)
    }
    elif(var(VAR_IONIA_CITY_STATE) >= 3){
        call(SVLMapScriptP3)
    }
    elif(var(VAR_ASPEN_EVENTS) == 1){
        call(SVLMapScriptP4)
    }
    elif(var(VAR_ASPEN_EVENTS) == 7){
        call(SVLMapScriptP5)
    }
    elif(var(VAR_ASPEN_EVENTS) == 8){
        call(SVLMapScriptP6)
    }
    else{
        return
    }
}

script SVLMapScriptP1{
    setflag(FLAG_HIDE_LAB_BALL)
    setflag(FLAG_HIDE_LAB_BALL2)
    setflag(FLAG_HIDE_LAB_BALL3)
    removeobject(Ball1)
    removeobject(Ball2)
    removeobject(Ball3)
    return
}

script SVLMapScriptP2{
    checkplayergender
    goto_if_eq(VAR_RESULT, MALE, SVLMapScriptA)
    goto_if_eq(VAR_RESULT, FEMALE, SVLMapScriptB)
    return
}

script SVLMapScriptP3{
    checkplayergender
    goto_if_eq(VAR_RESULT, MALE, SVLMapScriptC)
    goto_if_eq(VAR_RESULT, FEMALE, SVLMapScriptD)
    return
}

script SVLMapScriptP4{
    setobjectxyperm(SVLabAspen, 6, 11)
    setobjectmovementtype(SVLabAspen, MOVEMENT_TYPE_FACE_UP)
    playbgm(MUS_RG_OAK_LAB, FALSE)
    return
}

script SVLMapScriptP5{
    setobjectxyperm(SVLabAspen, 6, 11)
    setobjectmovementtype(SVLabAspen, MOVEMENT_TYPE_FACE_UP)
    return
}

script SVLMapScriptP6{
    setvar(VAR_ASPEN_LAB_EVENT, 9)
    return
}

script SVLMapScriptA{
    addobject(SVLabEgypt)
    clearflag(FLAG_HIDE_LAB_TWIN)
    setobjectxyperm(SVLabEgypt, 2, 2)
    setobjectmovementtype(SVLabEgypt, MOVEMENT_TYPE_FACE_UP)
    return
}

script SVLMapScriptB{
    addobject(SVLabAnthony)
    clearflag(FLAG_HIDE_LAB_TWIN)
    setobjectxyperm(SVLabAnthony, 2, 2)
    setobjectmovementtype(SVLabAnthony, MOVEMENT_TYPE_FACE_UP)
    return
}

script SVLMapScriptC{
    addobject(SVLabEgypt)
    clearflag(FLAG_HIDE_LAB_TWIN)
    setobjectxyperm(SVLabEgypt, 2, 6)
    setobjectmovementtype(SVLabEgypt, MOVEMENT_TYPE_FACE_UP)
    return
}

script SVLMapScriptD{
    addobject(SVLabAnthony)
    clearflag(FLAG_HIDE_LAB_TWIN)
    setobjectxyperm(SVLabAnthony, 2, 6)
    setobjectmovementtype(SVLabAnthony, MOVEMENT_TYPE_FACE_UP)
    return
}

script OnLoadSVLab{
    if(flag(FLAG_PROF_ASPEN_IMPROVEMENT)){
        setmetatile(0, 10, METATILE_WishLab_LabTile1, FALSE)
        setmetatile(3, 12, METATILE_WishLab_LabTile2, FALSE)
        setmetatile(8, 12, METATILE_WishLab_LabTile2, FALSE)
        setmetatile(9, 12, METATILE_WishLab_LabTile2, FALSE)
        setmetatile(10, 11, METATILE_WishLab_LabTile2, FALSE)
        setmetatile(11, 10, METATILE_WishLab_LabTile2, FALSE)
        setmetatile(4, 5, METATILE_WishLab_LabTile2, FALSE)
        setmetatile(11, 3, METATILE_WishLab_LabTile2, FALSE)
        setmetatile(12, 3, METATILE_WishLab_LabTile2, FALSE)
    }
}

script SapphireVillage_Lab_EventScript_PC{
    if(flag(FLAG_PROF_ASPEN_IMPROVEMENT)){
        msgbox("It's Professor Aspen's PC…\pThere are many files containing\nPokémon research data!")
        release
    }
    else{
        msgbox("It's Professor Aspen's PC…\nYuck! Shouldn't have looked!")
        release
    }
}

script SapphireVillage_Lab_EventScript_Boxes{
    if(flag(FLAG_PROF_ASPEN_IMPROVEMENT)){
        msgbox("The box is filled with what looks like\nPokémon Research textbooks.")
        release
    }
    else{
        msgbox("The box is filled with what looks like\nempty bottles and paraphernalia.")
        release
    } 
}

script SapphireVillage_Lab_EventScript_Balls{
    lock
    if(var(VAR_ASPEN_LAB_EVENT) >= 3){
        msgbox("It's an empty Poké Ball…")
        release
    }
    else{
        msgbox("It's a Poké Ball!\nBetter leave it alone for now.")
        release
    }
}

script SapphireVillage_Lab_EventScript_Dexes{
    msgbox("It's a Pokédex!\nBetter not touch it.")
    release
}

script SapphireVillage_Lab_EventScript_Jonathan{
    lock
    faceplayer
    if(flag(FLAG_PROF_ASPEN_IMPROVEMENT)){
        msgbox("{COLOR BLUE}Jonathan: Oh, hello {COLOR GREEN}{PLAYER}{COLOR BLUE}.\pProfessor Aspen has been much more\nproductive lately.\pThank you for all your help!")
        release
    }
    elif(var(VAR_JONATHAN_STATE) >= 1){
        msgbox("{COLOR BLUE}Jonathan: Good luck out there!\nPlease do your best to stay safe.")
        release
    }
    elif(flag(FLAG_BADGE01_GET)){
        msgbox("{COLOR BLUE}Jonathan: Good luck out there!\nPlease do your best to stay safe.")
        release
    }
    else{
        msgbox("{COLOR BLUE}Jonathan: Hello, {COLOR GREEN}{PLAYER}{COLOR BLUE}.\pProf. Aspen went out to look for you.\nHe should be back soon.\pPlease don't break anything like your\nbrother Alex did…")
        release
    }
}

script SapphireVillage_Lab_EventScript_Anthony{
    lock
    faceplayer
    if(flag(FLAG_IS_CHAMPION)){
        createfieldmugshot(MUGSHOT_ANTHONY, 0)
        msgbox("{COLOR BLUE}Anthony: Hey, {COLOR GREEN}{PLAYER}{COLOR BLUE}!\pHow's Kate's new villa?\nThink I should pay it a visit?")
        closemessage
        removefieldmugshot
        release
        end
    }
    elif(var(VAR_IONIA_CITY_STATE) >= 2){
        if(flag(FLAG_OBTAINED_TOTODILE)){
            createfieldmugshot(MUGSHOT_ANTHONY, 0)
            msgbox("{COLOR BLUE}Anthony: Hey, {COLOR GREEN}{PLAYER}{COLOR BLUE}!\pI heard that Amber will groom your\nPokémon for you.\pYou should check it out for yourself\nsometime!")
            closemessage
            removefieldmugshot
            release
            end
        }
        else{
            createfieldmugshot(MUGSHOT_ANTHONY, 0)
            msgbox("{COLOR BLUE}Anthony: Hey, {COLOR GREEN}{PLAYER}{COLOR BLUE}!\pAre you here for your Totodile?\nHere you go!")
            closemessage
            removefieldmugshot
            delay(50)
            givemon(SPECIES_TOTODILE, 10, ITEM_NONE, ITEM_POKE_BALL, NATURE_NAUGHTY, 0, 0, 0, 0, 0, 0, 0, 0, 21, 21, 21, 21, 21, 21, MOVE_SCRATCH, MOVE_LEER, MOVE_WATER_GUN, MOVE_RAGE, 0, 0, 0, 0)
            if(var(VAR_RESULT) == MON_GIVEN_TO_PARTY){
                playfanfare(MUS_OBTAIN_ITEM)
                msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
                waitfanfare
                waitmessage
                playbgm(MUS_RG_OAK_LAB, FALSE)
                call(NicknamePartyMon)
                goto(TwinLabA2)
                }
            elif(var(VAR_RESULT) == MON_GIVEN_TO_PC){
                playfanfare(MUS_OBTAIN_ITEM)
                msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
                waitfanfare
                waitmessage
                playbgm(MUS_RG_OAK_LAB, FALSE)
                call(NicknameBoxMon)
                goto(TwinLabA2)
                }
            else{
                msgbox("There's no more room for Pokémon!\pThe Pokémon Boxes are full and can't\naccept any more!")
                waitmessage
                playbgm(MUS_RG_OAK_LAB, FALSE)
                delay(45)
                createfieldmugshot(MUGSHOT_ANTHONY, 0)
                msgbox("{COLOR BLUE}Really sis?\nClean out your PC Boxes.")
                closemessage
                removefieldmugshot
                release
                end
                }
            }
        }
    else{
        createfieldmugshot(MUGSHOT_ANTHONY, 0)
        msgbox("{COLOR BLUE}Anthony: Hey, {COLOR GREEN}{PLAYER}{COLOR BLUE}!\nI have my work cut out for me here…")
        closemessage
        removefieldmugshot
        release
        end
    }
}

script TwinLabA2{
    delay(45)
    createfieldmugshot(MUGSHOT_ANTHONY, 0)
    msgbox("{COLOR BLUE}It looks pretty happy to meet ya!\nI'm sure you two will get along.")
    closemessage
    removefieldmugshot
    setflag(FLAG_OBTAINED_TOTODILE)
    setvar(VAR_IONIA_CITY_STATE, 3)
    release
    end
}

script TwinLabAA{
    delay(45)
    createfieldmugshot(MUGSHOT_EGYPT, 0)
    msgbox("{COLOR RED}Doesn't it look happy to meet you?\nI'm sure you two will get along.")
    closemessage
    removefieldmugshot
    setflag(FLAG_OBTAINED_TOTODILE)
    setvar(VAR_IONIA_CITY_STATE, 3)
    release
    end
}

script SapphireVillage_Lab_EventScript_Egypt{
    lock
    faceplayer
    if(flag(FLAG_IS_CHAMPION)){
        createfieldmugshot(MUGSHOT_EGYPT, 0)
        msgbox("{COLOR RED}Egypt: Hey, {COLOR GREEN}{PLAYER}{COLOR RED}!\pHow's Katelyn's new villa?\nI should totally visit sometime!")
        closemessage
        removefieldmugshot
        release
        end
    }
    elif(var(VAR_IONIA_CITY_STATE) >= 2){
        if(flag(FLAG_OBTAINED_TOTODILE)){
            createfieldmugshot(MUGSHOT_EGYPT, 0)
            msgbox("{COLOR RED}Egypt: Hey, {COLOR GREEN}{PLAYER}{COLOR RED}!\pI heard that Amber will groom your\nPokémon for you.\pYou should pay her a visit!")
            closemessage
            removefieldmugshot
            release
            end
        }
        else{
            createfieldmugshot(MUGSHOT_EGYPT, 0)
            msgbox("{COLOR RED}Egypt: Hey, {COLOR GREEN}{PLAYER}{COLOR RED}!\pAre you here for Totodile?\nHere you go!")
            closemessage
            removefieldmugshot
            delay(50)
            givemon(SPECIES_TOTODILE, 10, ITEM_NONE, ITEM_POKE_BALL, NATURE_NAUGHTY, 0, 0, 0, 0, 0, 0, 0, 0, 21, 21, 21, 21, 21, 21, MOVE_SCRATCH, MOVE_LEER, MOVE_WATER_GUN, MOVE_RAGE, 0, 0, 0, 0)
            if(var(VAR_RESULT) == MON_GIVEN_TO_PARTY){
                playfanfare(MUS_OBTAIN_ITEM)
                msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
                waitfanfare
                waitmessage
                playbgm(MUS_RG_OAK_LAB, FALSE)
                call(NicknamePartyMon)
                goto(TwinLabAA)
                }
            elif(var(VAR_RESULT) == MON_GIVEN_TO_PC){
                playfanfare(MUS_OBTAIN_ITEM)
                msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} received the Totodile!")
                waitfanfare
                waitmessage
                playbgm(MUS_RG_OAK_LAB, FALSE)
                call(NicknameBoxMon)
                goto(TwinLabAA)
                }
            else{
                msgbox("There's no more room for Pokémon!\pThe Pokémon Boxes are full and can't\naccept any more!")
                waitmessage
                playbgm(MUS_RG_OAK_LAB, FALSE)
                delay(45)
                createfieldmugshot(MUGSHOT_EGYPT, 0)
                msgbox("{COLOR RED}Really bro?\nClean out your PC Boxes.")
                closemessage
                removefieldmugshot
                release
                end
                }
            }
        }
    else{
        createfieldmugshot(MUGSHOT_EGYPT, 0)
        msgbox("{COLOR RED}Egypt: Hey, {COLOR GREEN}{PLAYER}{COLOR RED}!\nI have my work cut out for me here…")
        closemessage
        removefieldmugshot
        release
        end
    }
}

script SapphireVillage_Lab_EventScript_Aspen{
    lock
    faceplayer
    if(flag(FLAG_TEMP_2)){
        createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
        msgbox("{COLOR BLUE}Prof. Aspen: Don't let me keep you.\nI'm sure you have some place to be.")
        removefieldmugshot
        release
    }
    elif(flag(FLAG_PROF_ASPEN_IMPROVEMENT)){
        createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
        msgbox("{COLOR BLUE}Prof. Aspen: Hey, {COLOR GREEN}{PLAYER}{COLOR BLUE}.\pI wanted to thank you and your family\nfor everything.\pNow that I'm on the straight and narrow,\nI can focus on my Pokémon research.\pThe Professors are even starting to\ninvite me to meetings again!\pI even cleaned up my house and the lab.\nHope ya like the new look!\pOh yeah, and keep at it with the\nPokédex. It's really helping out.")
        removefieldmugshot
        setflag(FLAG_TEMP_2)
        release
    }
    elif(flag(FLAG_SYS_POKEDEX_GET)){
        createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
        msgbox("{COLOR BLUE}Prof. Aspen: I'm counting on ya.\nPlease help me out here.\pYou can get your Pokédex rated at any\nPC inside a Pokémon Center.")
        removefieldmugshot
        release
    }
    elif(flag(FLAG_BUNEARY_OBTAINED)){
        createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
        msgbox("{COLOR BLUE}Prof. Aspen: You got the package yet?\nC'mon, kid. Not asking for much.")
        removefieldmugshot
        release
    }
    else{
        createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
        msgbox("{COLOR BLUE}Prof. Aspen: Once you get to Jasper\nTown, head towards the Pokémart.\pOnce you're there, ask for a guy named\nMack and tell 'em I sent ya.\pDon't let the feds catch ya either.\nIf they do, then I don't know ya.")
        removefieldmugshot
        release
    }
}

script SapphireVillage_Lab_EventScript_LabEventBA{
    lockall
    applymovement(OBJ_EVENT_ID_PLAYER, movPlayerlab3)
    waitmovement(0)
    delay(30)
    playse(21)
    applymovement(SVLabAspen, movAspenlab1)
    waitmovement(0)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Prof. Aspen: Oh hey, you're back!\nSo you got the goods, right?")
    closemessage
    removefieldmugshot
    delay(30)
    playfanfare(MUS_RG_OBTAIN_KEY_ITEM)
    msgbox("{COLOR GREEN}{PLAYER}{COLOR DARK_GRAY} delivered the Odd Package!")
    closemessage
    waitfanfare
    removeitem(ITEM_PARCEL, 1)
    delay(30)
    createfieldmugshot(MUGSHOT_PROF_ASPEN, 0)
    msgbox("{COLOR BLUE}Finally, I've gone way too long without\na drink.\p…\pRight, our little deal we made.\nWe have a bit of a problem.\pI managed to get ahold of more Pokémon,\nbut I can't access 'em.")
    closemessage
    removefieldmugshot
    delay(45)
    checkplayergender
    goto_if_eq(VAR_RESULT, MALE, LabEventBAM)
    goto_if_eq(VAR_RESULT, FEMALE, LabEventBAF)
}

